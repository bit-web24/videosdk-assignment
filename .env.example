# ── WebSocket Server Config ──────────────────────────────
# Unique identifier for this region (e.g. us-east, eu-west)
REGION_ID=us-east

# Port the WebSocket server listens on inside the container
PORT=3000

# ── NATS Config ──────────────────────────────────────────
# NATS server URL for inter-region messaging
NATS_URL=nats://localhost:4222

# ── Logging ──────────────────────────────────────────────
# Log level: trace | debug | info | warn | error
RUST_LOG=info
